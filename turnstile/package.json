{
  "name": "@itd-api/turnstile",
  "version": "0.0.1",
  "description": "Получение токена Cloudflare Turnstile для входа в itd-api через локальный браузер",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KiowDev/itd-api.git",
    "directory": "turnstile"
  },
  "homepage": "https://github.com/KiowDev/itd-api/tree/main/turnstile",
  "bugs": {
    "url": "https://github.com/KiowDev/itd-api/issues"
  },
  "author": "Kiow",
  "keywords": [
    "itd",
    "turnstile",
    "cloudflare",
    "playwright",
    "captcha"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit",
    "check:pack": "publint && attw --pack .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run check:pack"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^26.1.1",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
