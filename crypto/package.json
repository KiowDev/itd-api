{
  "name": "itd-api-crypto",
  "version": "0.0.1",
  "description": "Скрытые сообщения в постах и профилях итд.com: плагин шифрования для itd-api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KiowDev/itd-api.git",
    "directory": "crypto"
  },
  "homepage": "https://github.com/KiowDev/itd-api/tree/main/crypto",
  "bugs": {
    "url": "https://github.com/KiowDev/itd-api/issues"
  },
  "author": "Kiow",
  "keywords": [
    "itd",
    "itd-api",
    "plugin",
    "steganography",
    "cipher",
    "zero-width"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check:pack": "publint && attw --pack .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run check:pack"
  },
  "peerDependencies": {
    "itd-api": ">=0.0.6"
  },
  "peerDependenciesMeta": {
    "itd-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^26.1.1",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
